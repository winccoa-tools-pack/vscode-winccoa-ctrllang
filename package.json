{
  "name": "winccoa-ctrllang",
  "displayName": "WinCC OA CTRL Language Support",
  "description": "Language support for WinCC OA CTRL and CTRL++ - syntax highlighting, goto definition",
  "publisher": "RichardJanisch",
  "version": "2.0.2",
  "author": "RichardJanisch",
  "license": "GNU General Public License v3.0",
  "icon": "resources/wincc_oa_ctrl_lang_512.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/winccoa-tools-pack/vscode-winccoa-ctrllang"
  },
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "WinCC OA",
    "CTRL",
    "CTRL++",
    "ctl",
    "ctlpp",
    "SCADA",
    "language support",
    "syntax highlighting",
    "intellisense"
  ],
  "extensionDependencies": [
    "RichardJanisch.winccoa-project-admin"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:ctrl",
    "onLanguage:ctrlpp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ctrl",
        "aliases": [
          "WinCC OA CTRL",
          "ctrl"
        ],
        "extensions": [
          ".ctl",
          ".ctrl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icons/ctl-file.svg",
          "dark": "./resources/icons/ctl-file.svg"
        }
      },
      {
        "id": "ctrlpp",
        "aliases": [
          "WinCC OA CTRL++",
          "ctrl++"
        ],
        "extensions": [
          ".ctlpp",
          ".ctrlpp"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icons/ctl-file.svg",
          "dark": "./resources/icons/ctl-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ctrl",
        "scopeName": "source.ctrl",
        "path": "./syntaxes/ctrl.tmLanguage.json"
      },
      {
        "language": "ctrlpp",
        "scopeName": "source.ctrlpp",
        "path": "./syntaxes/ctrlpp.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "winccoa.openDocumentation",
        "title": "Open Documentation for CTRL Function",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.formatDocument",
        "title": "Format Document with Astyle",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.runSyntaxCheck",
        "title": "Run WinCC OA Syntax Check",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.insertTestTemplate",
        "title": "Insert Test Template",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.insertScriptTemplate",
        "title": "Insert Script Template",
        "category": "WinCC OA"
      }
    ],
    "languageModelTools": [
      {
        "name": "ctl_syntax_check",
        "displayName": "Check CTL Syntax",
        "modelDescription": "Check CTL files for syntax errors. Returns list of errors with line numbers, messages, and severity. Use when the user asks to validate code, check for errors, or analyze CTL files.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "ctl_syntax",
        "icon": "$(warning)",
        "userDescription": "Check CTL code for syntax errors",
        "inputSchema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "Absolute path to the CTL file to check"
            }
          },
          "required": ["file"]
        }
      },
      {
        "name": "ctl_get_diagnostics",
        "displayName": "Get CTL Diagnostics",
        "modelDescription": "Get all diagnostics (errors, warnings, info, hints) for a CTL file. Use when the user wants detailed analysis, warnings, or complete diagnostic information about their code.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "ctl_diagnostics",
        "icon": "$(info)",
        "userDescription": "Get all diagnostics for a CTL file",
        "inputSchema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "Absolute path to the CTL file"
            }
          },
          "required": ["file"]
        }
      },
      {
        "name": "ctl_get_symbol_info",
        "displayName": "Get CTL Symbol Info",
        "modelDescription": "Get hover information for a symbol at a specific position in a CTL file. Returns function signatures, variable types, documentation. Use when the user asks what a function does, wants to see a signature, or needs information about a symbol.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "ctl_symbol",
        "icon": "$(symbol-method)",
        "userDescription": "Get information about a CTL symbol",
        "inputSchema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "Absolute path to the CTL file"
            },
            "line": {
              "type": "number",
              "description": "Line number (1-based)"
            },
            "column": {
              "type": "number",
              "description": "Column number (1-based)"
            }
          },
          "required": ["file", "line", "column"]
        }
      },
      {
        "name": "ctl_find_references",
        "displayName": "Find CTL References",
        "modelDescription": "Find all references to a symbol across the workspace. Use when the user asks where a function is used, wants to see all usages of a variable, or needs to refactor code.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "ctl_references",
        "icon": "$(references)",
        "userDescription": "Find all references to a CTL symbol",
        "inputSchema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "Absolute path to the CTL file"
            },
            "line": {
              "type": "number",
              "description": "Line number (1-based)"
            },
            "column": {
              "type": "number",
              "description": "Column number (1-based)"
            }
          },
          "required": ["file", "line", "column"]
        }
      },
      {
        "name": "ctl_goto_definition",
        "displayName": "Go to CTL Definition",
        "modelDescription": "Get the definition location(s) of a symbol. Use when the user asks where a function is defined, wants to jump to a declaration, or needs to find the source of a symbol.",
        "canBeReferencedInPrompt": true,
        "toolReferenceName": "ctl_definition",
        "icon": "$(go-to-file)",
        "userDescription": "Find the definition of a CTL symbol",
        "inputSchema": {
          "type": "object",
          "properties": {
            "file": {
              "type": "string",
              "description": "Absolute path to the CTL file"
            },
            "line": {
              "type": "number",
              "description": "Line number (1-based)"
            },
            "column": {
              "type": "number",
              "description": "Column number (1-based)"
            }
          },
          "required": ["file", "line", "column"]
        }
      }
    ],
    "configuration": {
      "title": "WinCC OA CTRL Language",
      "properties": {
        "winccoa.ctrlLang.pathSource": {
          "type": "string",
          "enum": [
            "workspace",
            "manual",
            "automatic"
          ],
          "default": "automatic",
          "description": "How to resolve WinCC OA project paths",
          "enumDescriptions": [
            "Auto-detect from workspace (searches for config/config file in all workspace folders)",
            "Manual configuration (specify paths below)",
            "Automatically detect from selected WinCC OA project (requires Core extension)"
          ]
        },
        "winccoa.ctrlLang.projectPath": {
          "type": "string",
          "default": "",
          "description": "Main WinCC OA project path (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.installPath": {
          "type": "string",
          "default": "",
          "description": "WinCC OA installation path (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.subProjects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of subproject paths (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.additionalScriptsPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional scripts folders to search in (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.logLevel": {
          "type": "string",
          "enum": [
            "ERROR",
            "WARN",
            "INFO",
            "DEBUG",
            "TRACE"
          ],
          "default": "INFO",
          "description": "Logging level for extension output",
          "enumDescriptions": [
            "Only critical errors",
            "Errors and warnings",
            "General information, errors and warnings (recommended)",
            "Detailed debugging information",
            "Very verbose trace information (for troubleshooting)"
          ]
        },
        "winccoa.astyleFormatter.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Astyle code formatting for .ctl/.ctrlpp files"
        },
        "winccoa.astyleFormatter.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to astyle binary. If empty, uses WinCC OA installation path (bin/astyle or bin/astyle.exe)"
        },
        "winccoa.astyleFormatter.configPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to astyle config file. If empty, uses WinCC OA installation path (config/astyle.config)"
        },
        "winccoa.astyleFormatter.runOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format files when saving"
        },
        "winccoa.syntaxCheck.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable WinCC OA native syntax checking"
        },
        "winccoa.syntaxCheck.executeOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run syntax check automatically when saving .ctl/.ctrlpp files"
        },
        "winccoa.templates.autoSuggest": {
          "type": "boolean",
          "default": true,
          "description": "Automatically suggest template insertion when creating new .ctl files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run build:functions && tsc -p ./ && cd language-server && tsc -p ./",
    "build": "npm run compile",
    "build:functions": "ts-node tools/scripts/build-functions.ts",
    "watch": "tsc -watch -p ./",
    "watch:server": "cd language-server && tsc -watch -p ./",
    "package": "vsce package",
    "lint": "echo \"Lint passed\"",
    "style-check": "npm run lint",
    "test": "node ./dist/test/runTest.js",
    "test:unit": "npm test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.4",
    "@types/vscode": "^1.105.0",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vscode/test-electron": "^2.3.9",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^9.36.0",
    "glob": "^13.0.0",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
