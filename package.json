{
  "name": "winccoa-ctrllang",
  "displayName": "WinCC OA CTRL Language Support",
  "description": "Language support for WinCC OA CTRL and CTRL++ - syntax highlighting, goto definition",
  "publisher": "RichardJanisch",
  "version": "1.3.1",
  "author": "RichardJanisch",
  "license": "GNU General Public License v3.0",
  "icon": "resources/wincc_oa_ctrl_lang_512.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/winccoa-tools-pack/vscode-winccoa-ctrllang"
  },
  "bugs": {
    "url": "https://github.com/winccoa-tools-pack/vscode-winccoa-ctrllang/issues"
  },
  "homepage": "https://github.com/winccoa-tools-pack/vscode-winccoa-ctrllang#readme",
  "engines": {
    "vscode": "^1.109.2"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters",
    "Snippets"
  ],
  "keywords": [
    "wincc-oa",
    "winccoa",
    "scada",
    "hmi",
    "siemens",
    "etm",
    "industrial",
    "automation",
    "ctrl",
    "ctrlpp",
    "WinCC OA",
    "CTRL",
    "CTRL++",
    "ctl",
    "ctlpp",
    "SCADA",
    "language support",
    "syntax highlighting",
    "intellisense"
  ],
  "extensionDependencies": [
    "RichardJanisch.winccoa-project-admin"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:ctrl",
    "onLanguage:ctrlpp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ctrl",
        "aliases": [
          "WinCC OA CTRL",
          "ctrl"
        ],
        "extensions": [
          ".ctl",
          ".ctrl"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icons/ctl-file.svg",
          "dark": "./resources/icons/ctl-file.svg"
        }
      },
      {
        "id": "ctrlpp",
        "aliases": [
          "WinCC OA CTRL++",
          "ctrl++"
        ],
        "extensions": [
          ".ctlpp",
          ".ctrlpp"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./resources/icons/ctl-file.svg",
          "dark": "./resources/icons/ctl-file.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ctrl",
        "scopeName": "source.ctrl",
        "path": "./syntaxes/ctrl.tmLanguage.json"
      },
      {
        "language": "ctrlpp",
        "scopeName": "source.ctrlpp",
        "path": "./syntaxes/ctrlpp.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "winccoa.openDocumentation",
        "title": "Open Documentation for CTRL Function",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.formatDocument",
        "title": "Format Document with Astyle",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.runSyntaxCheck",
        "title": "Run WinCC OA Syntax Check",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.insertTestTemplate",
        "title": "Insert Test Template",
        "category": "WinCC OA"
      },
      {
        "command": "winccoa.insertScriptTemplate",
        "title": "Insert Script Template",
        "category": "WinCC OA"
      }
    ],
    "configuration": {
      "title": "WinCC OA CTRL Language",
      "properties": {
        "winccoa.ctrlLang.pathSource": {
          "type": "string",
          "enum": [
            "workspace",
            "manual",
            "automatic"
          ],
          "default": "automatic",
          "description": "How to resolve WinCC OA project paths",
          "enumDescriptions": [
            "Auto-detect from workspace (searches for config/config file in all workspace folders)",
            "Manual configuration (specify paths below)",
            "Automatically detect from selected WinCC OA project (requires Core extension)"
          ]
        },
        "winccoa.ctrlLang.projectPath": {
          "type": "string",
          "default": "",
          "description": "Main WinCC OA project path (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.installPath": {
          "type": "string",
          "default": "",
          "description": "WinCC OA installation path (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.subProjects": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "List of subproject paths (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.additionalScriptsPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional scripts folders to search in (only used when pathSource is 'manual')"
        },
        "winccoa.ctrlLang.logLevel": {
          "type": "string",
          "enum": [
            "ERROR",
            "WARN",
            "INFO",
            "DEBUG",
            "TRACE"
          ],
          "default": "INFO",
          "description": "Logging level for extension output",
          "enumDescriptions": [
            "Only critical errors",
            "Errors and warnings",
            "General information, errors and warnings (recommended)",
            "Detailed debugging information",
            "Very verbose trace information (for troubleshooting)"
          ]
        },
        "winccoa.astyleFormatter.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Astyle code formatting for .ctl/.ctrlpp files"
        },
        "winccoa.astyleFormatter.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to astyle binary. If empty, uses WinCC OA installation path (bin/astyle or bin/astyle.exe)"
        },
        "winccoa.astyleFormatter.configPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to astyle config file. If empty, uses WinCC OA installation path (config/astyle.config)"
        },
        "winccoa.astyleFormatter.runOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically format files when saving"
        },
        "winccoa.syntaxCheck.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable WinCC OA native syntax checking"
        },
        "winccoa.syntaxCheck.executeOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Run syntax check automatically when saving .ctl/.ctrlpp files"
        },
        "winccoa.templates.autoSuggest": {
          "type": "boolean",
          "default": true,
          "description": "Automatically suggest template insertion when creating new .ctl files"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "check:changelog": "node scripts/check-changelog-version.mjs",
    "generate:changelog": "node scripts/generate-changelog.mjs",
    "generate:changelog:write": "node scripts/generate-changelog.mjs --write",
    "compile": "webpack && cd language-server && tsc -p ./",
    "clean:out": "node -e \"require('fs').rmSync('out',{ recursive:true, force:true, maxRetries:10, retryDelay:200 })\"",
    "clean:out-tests": "node -e \"try{require('fs').rmSync('out/test',{ recursive:true, force:true, maxRetries:10, retryDelay:200 })}catch(e){console.warn('clean:out-tests skipped:', e.message)}\"",
    "clean:coverage": "node -e \"require('fs').rmSync('coverage',{ recursive:true, force:true, maxRetries:10, retryDelay:200 })\"",
    "clean:coverage:unitTests": "node -e \"require('fs').rmSync('coverage/unitTests',{ recursive:true, force:true, maxRetries:10, retryDelay:200 })\"",
    "clean:coverage:integrationTests": "node -e \"require('fs').rmSync('coverage/integrationTests',{ recursive:true, force:true, maxRetries:10, retryDelay:200 })\"",
    "compile:tsc": "tsc -p ./ && npm run copy-fixtures",
    "copy-fixtures": "copyfiles -u 1 \"src/test/fixtures/**/*\" out/",
    "start": "code --extensionDevelopmentPath=.",
    "start:insiders": "code-insiders --extensionDevelopmentPath=.",
    "dev": "npm run watch",
    "watch": "webpack --watch",
    "pretest": "npm run compile && npm run compile:tsc && npm run lint",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "lint:md": "markdownlint \"**/*.md\" --ignore node_modules",
    "lint:md:fix": "markdownlint \"**/*.md\" --ignore node_modules --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vscode-test --label unitTests",
    "test:integration": "vscode-test --label integrationTests",
    "test:unit:coverage": "npm run compile:tsc && npm run clean:coverage:unitTests && vscode-test --label unitTests --coverage --coverage-output coverage/unitTests --coverage-reporter lcov --coverage-reporter html --coverage-reporter json-summary --coverage-reporter text-summary",
    "test:integration:coverage": "npm run compile:tsc && npm run clean:coverage:integrationTests && vscode-test --label integrationTests --coverage --coverage-output coverage/integrationTests --coverage-reporter lcov --coverage-reporter html --coverage-reporter json-summary --coverage-reporter text-summary",
    "test:coverage": "npm run test:unit:coverage && npm run test:integration:coverage",
    "ci:integration": "npm ci && npm run compile && npm run test:integration",
    "style-check": "npm run format:check && npm run lint",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "^25.2.3",
    "@types/vscode": "^1.107.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.0.2",
    "glob": "^13.0.3",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli": "^0.47.0",
    "mocha": "^11.7.5",
    "prettier": "^2.8.8",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.0",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1"
  },
  "overrides": {
    "diff": "8.0.3",
    "minimatch": "10.2.2",
    "mocha": {
      "minimatch": "10.2.2"
    },
    "@vscode/test-cli": {
      "minimatch": "10.2.2"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "10.2.2"
    },
    "markdownlint-cli": {
      "minimatch": "10.2.2"
    },
    "@vscode/vsce": {
      "minimatch": "10.2.2"
    }
  },
  "config": {
    "winccoaImage": "mpokornyetm/winccoa-tools-pack-npm-winccoa-core:npm-winccoa-core"
  },
  "lint-staged": {
    "*.ts": "npm run format",
    "*.md": "markdownlint --fix"
  },
  "dependencies": {
    "@winccoa-tools-pack/npm-winccoa-core": "0.2.6",
    "fast-xml-parser": "^4.5.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}