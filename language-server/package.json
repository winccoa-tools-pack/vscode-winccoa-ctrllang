{
  "name": "winccoa-ctrllang-language-server",
  "version": "0.2.0",
  "description": "Language Server for WinCC OA CTRL",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p . && tsc -p tsconfig.build.json && npm run copy-fixtures",
    "copy-fixtures": "mkdir -p ../dist/language-server/test/simple/fixtures && cp test/simple/fixtures/*.ctl ../dist/language-server/test/simple/fixtures/ && mkdir -p ../dist/test-workspace/scripts && cp -r ../test-workspace/scripts/* ../dist/test-workspace/scripts/",
    "test": "npm run build && mocha --ui tdd '../dist/language-server/test/**/*.test.js'",
    "test:watch": "mocha --ui tdd --watch '../dist/language-server/test/**/*.test.js'"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.5",
    "mocha": "^11.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  }
}
